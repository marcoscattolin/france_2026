  <!-- Blue — Parigi (G3, G4) -->
  <Style id="s-par-pt"><IconStyle><color>ff7c4b2a</color><scale>1.2</scale><Icon><href>http://maps.google.com/mapfiles/kml/shapes/placemark_circle.png</href></Icon></IconStyle><LabelStyle><color>ff7c4b2a</color><scale>0.9</scale></LabelStyle></Style>
  <Style id="s-par-ln"><LineStyle><color>cc7c4b2a</color><width>5</width></LineStyle></Style>
  <!-- Dark Blue — Normandia (G5, G6, G7) -->
  <Style id="s-nor-pt"><IconStyle><color>ff724a1a</color><scale>1.2</scale><Icon><href>http://maps.google.com/mapfiles/kml/shapes/placemark_circle.png</href></Icon></IconStyle><LabelStyle><color>ff724a1a</color><scale>0.9</scale></LabelStyle></Style>
