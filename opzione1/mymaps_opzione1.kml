  <Folder>
    <name>G11 · Lun 31 Ago · Chambéry → Milano · Consegna ✅</name>
    <description>⚠ Partenza ore 05:00 · ~361 km · Traforo del Fréjus · A32 → Torino → A4 → Milano</description>

    <Placemark>
      <name>🚇 Traforo del Fréjus · Modane (FR)</name>
      <description>Passaggio ~06:45. Pedaggio ~€60/camper. 12,9 km sotto le Alpi.
Ingresso FR: Modane · Uscita IT: Bardonecchia.</description>
      <styleUrl>#s-ret-pt</styleUrl>
      <Point><coordinates>6.6621,45.2043,0</coordinates></Point>
    </Placemark>

    <Placemark>
