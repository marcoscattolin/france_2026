<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>Francia Camper v3 — 21-31 Agosto 2025</name>
    <description>Percorso ottimizzato: Milano → Reims → Versailles/Parigi → Disneyland (mar 25) → Mont-Saint-Michel → Normandia → Loira → Milano
4 camper · 4 famiglie · bambini 8-10 anni · 10 notti</description>
    <Style id="tappa">
      <IconStyle>
        <color>ffff8800</color>
        <scale>1.3</scale>
        <Icon>
          <href>http://maps.google.com/mapfiles/kml/paddle/blu-circle.png</href>
        </Icon>
      </IconStyle>
      <LabelStyle>
        <scale>0.8</scale>
      </LabelStyle>
    </Style>
