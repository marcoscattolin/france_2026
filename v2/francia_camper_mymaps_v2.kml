        <scale>0.8</scale>
      </LabelStyle>
    </Style>
    <Folder>
      <name>Tappe del percorso</name>
      <description>11 tappe dal 21 al 31 agosto</description>
      <Placemark>
        <name>1 - Milano (partenza)</name>
        <description>Ven 21 ago | Ritiro camper ore 15:00. Partenza verso Reims.</description>
        <styleUrl>#tappa</styleUrl>
        <Point>
          <coordinates>9.1859,45.4654,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>2 - Reims (1ª notte)</name>
        <description>Ven 21 ago | Prima tappa ~450 km. Champagne.</description>
        <styleUrl>#tappa</styleUrl>
        <Point>
          <coordinates>4.0317,49.2583,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>3 - Versailles (2ª notte)</name>
        <description>Sab 22 ago | Reims + trasferimento Versailles ~140 km.</description>
        <styleUrl>#tappa</styleUrl>
        <Point>
          <coordinates>2.1204,48.8049,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>4 - Versailles (3ª notte)</name>
        <description>Dom 23 ago | Reggia + Parigi compatta (Torre Eiffel, Sainte-Chapelle, Montmartre).</description>
        <styleUrl>#tappa</styleUrl>
        <Point>
          <coordinates>2.1204,48.8049,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>5 - Versailles (4ª notte)</name>
        <description>Lun 24 ago | Parigi libera: Louvre / Cité des Sciences / relax.</description>
        <styleUrl>#tappa</styleUrl>
        <Point>
          <coordinates>2.1204,48.8049,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>6 - Disneyland / Versailles</name>
        <description>Mar 25 ago | Disneyland Paris. MARTEDI = folla ridotta. RER A da Versailles.</description>
        <styleUrl>#tappa</styleUrl>
        <Point>
          <coordinates>2.7836,48.8674,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>7 - Mont-Saint-Michel (5ª notte)</name>
        <description>Mer 26 ago | Trasferimento ~380 km. Arrivare dopo le 17.</description>
        <styleUrl>#tappa</styleUrl>
        <Point>
          <coordinates>-1.5116,48.6359,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>8 - Jullouville (6ª notte)</name>
        <description>Gio 27 ago | Abbazia Mont-Saint-Michel + spiagge Côte des Havres.</description>
        <styleUrl>#tappa</styleUrl>
        <Point>
          <coordinates>-1.5667,48.7833,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>9 - Étretat (7ª notte)</name>
        <description>Ven 28 ago | Bayeux + Omaha Beach + Pointe du Hoc + Étretat.</description>
        <styleUrl>#tappa</styleUrl>
        <Point>
          <coordinates>0.2083,49.7083,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>10 - Bracieux/Loira (8ª notte)</name>
        <description>Sab 29 ago | Honfleur + trasferimento Loira ~220 km.</description>
        <styleUrl>#tappa</styleUrl>
        <Point>
          <coordinates>1.5333,47.5667,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>11 - Tours/Loira (9ª notte)</name>
        <description>Dom 30 ago | Chambord + Chenonceau. Ultima sera.</description>
        <styleUrl>#tappa</styleUrl>
        <Point>
          <coordinates>0.69,47.39,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>12 - Milano (consegna)</name>
        <description>Lun 31 ago | Partenza ore 6:00. Consegna camper ore 9:00.</description>
        <styleUrl>#tappa</styleUrl>
        <Point>
          <coordinates>9.1859,45.4654,0</coordinates>
        </Point>
      </Placemark>
