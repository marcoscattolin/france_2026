    <Folder>
      <name>Luoghi da visitare</name>
      <Folder>
        <name>Champagne</name>
        <Placemark>
          <name>Cattedrale Notre-Dame — Reims</name>
          <description>Incoronazione dei re di Francia. Sosta mattino giorno 2.</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>4.0339,49.2533,0</coordinates>
          </Point>
        </Placemark>
      </Folder>
      <Folder>
        <name>Parigi e dintorni</name>
        <Placemark>
          <name>Reggia di Versailles</name>
          <description>Galleria degli Specchi + Giardini. Prenotare online.</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>2.1204,48.8049,0</coordinates>
          </Point>
        </Placemark>
        <Placemark>
          <name>Torre Eiffel</name>
          <description>PRENOTARE MESI PRIMA. Salita 2° piano. Picnic Champ-de-Mars.</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>2.2945,48.8584,0</coordinates>
          </Point>
        </Placemark>
        <Placemark>
          <name>Sainte-Chapelle</name>
          <description>Vetrate gotiche XIII sec. Imperdibile con bambini.</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>2.345,48.8554,0</coordinates>
          </Point>
        </Placemark>
        <Placemark>
          <name>Montmartre – Sacré-Cœur</name>
          <description>Vista panoramica su Parigi. Artisti in Place du Tertre.</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>2.3431,48.8867,0</coordinates>
          </Point>
        </Placemark>
        <Placemark>
          <name>Louvre</name>
          <description>Opzionale giorno libero. Egizie + Mona Lisa + Vittoria Samotracia.</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>2.3376,48.8606,0</coordinates>
          </Point>
        </Placemark>
        <Placemark>
          <name>Cité des Sciences — La Villette</name>
          <description>Museo scientifico interattivo — uno dei migliori d'Europa per bambini.</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>2.3878,48.8957,0</coordinates>
          </Point>
        </Placemark>
        <Placemark>
          <name>Disneyland Paris</name>
          <description>MARTEDI 25 agosto = folla ridotta. RER A diretto. PRENOTARE SUBITO.</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>2.7836,48.8674,0</coordinates>
          </Point>
        </Placemark>
      </Folder>
      <Folder>
        <name>Normandia</name>
        <Placemark>
          <name>Mont-Saint-Michel</name>
          <description>Abbazia UNESCO. Maree tra le più grandi d'Europa. Parking da prenotare.</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>-1.5116,48.6359,0</coordinates>
          </Point>
        </Placemark>
        <Placemark>
          <name>Bayeux — Arazzo XI sec.</name>
          <description>70 metri di storia normanna. Accessibile per bambini.</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>-0.7033,49.2764,0</coordinates>
          </Point>
        </Placemark>
        <Placemark>
          <name>Omaha Beach</name>
          <description>Spiaggia D-Day. Cimitero Americano di Colleville-sur-Mer.</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>-0.8611,49.3691,0</coordinates>
          </Point>
        </Placemark>
        <Placemark>
          <name>Pointe du Hoc</name>
          <description>Trincee e crateri intatti. I bambini restano affascinati.</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>-0.9917,49.3964,0</coordinates>
          </Point>
        </Placemark>
        <Placemark>
          <name>Scogliere di Étretat</name>
          <description>Scogliere bianche più famose d'Europa. Passeggiata falaise 1h.</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>0.2083,49.7083,0</coordinates>
          </Point>
        </Placemark>
        <Placemark>
          <name>Porto di Honfleur</name>
          <description>Porto più bello della Normandia. Case a graticcio sul Vieux Bassin.</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>0.2333,49.4189,0</coordinates>
          </Point>
        </Placemark>
      </Folder>
      <Folder>
        <name>Valle della Loira</name>
        <Placemark>
          <name>Château de Chambord</name>
