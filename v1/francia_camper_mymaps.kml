<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>🚐 Francia in Camper — 21-31 Agosto 2025</name>
    <description>Itinerario completo: 4 camper, 4 famiglie, bambini 8-10 anni | Milano → Loira → Normandia → Parigi → Milano</description>
    <Style id="tappa">
      <IconStyle>
        <color>ffff8800</color>
        <scale>1.3</scale>
        <Icon>
          <href>http://maps.google.com/mapfiles/kml/paddle/blu-circle.png</href>
        </Icon>
      </IconStyle>
      <LabelStyle>
        <scale>0.8</scale>
      </LabelStyle>
    </Style>
    <Style id="visita">
      <IconStyle>
        <color>ff00d4ff</color>
        <scale>1.2</scale>
        <Icon>
          <href>http://maps.google.com/mapfiles/kml/paddle/ylw-stars.png</href>
        </Icon>
      </IconStyle>
      <LabelStyle>
        <scale>0.8</scale>
      </LabelStyle>
    </Style>
    <Style id="camping">
      <IconStyle>
        <color>ff00aa00</color>
        <scale>1.1</scale>
        <Icon>
          <href>http://maps.google.com/mapfiles/kml/paddle/grn-square.png</href>
        </Icon>
      </IconStyle>
      <LabelStyle>
        <scale>0.8</scale>
      </LabelStyle>
    </Style>
    <Style id="area">
      <IconStyle>
        <color>ffaa00ff</color>
        <scale>1.0</scale>
        <Icon>
          <href>http://maps.google.com/mapfiles/kml/paddle/purple-circle.png</href>
        </Icon>
      </IconStyle>
      <LabelStyle>
        <scale>0.8</scale>
      </LabelStyle>
    </Style>
    <Folder>
      <name>🗓 Tappe del percorso</name>
      <description>Le 11 soste notte dell'itinerario dal 21 al 31 agosto</description>
      <Placemark>
        <name>1 - Milano (partenza)</name>
        <description>Ven 21 ago - Ritiro camper ore 15:00

Ritiro camper ore 15:00. Partenza verso Torino/Aosta.</description>
        <styleUrl>#tappa</styleUrl>
        <Point>
          <coordinates>9.1859,45.4654,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>2 - Torino / Aosta (1ª notte)</name>
        <description>Ven 21 ago - 1ª notte

Prima tappa corta dopo il ritiro. ~150 km da Milano.</description>
        <styleUrl>#tappa</styleUrl>
        <Point>
          <coordinates>7.6869,45.0703,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>3 - Mâcon (2ª notte)</name>
        <description>Sab 22 ago - 2ª notte

Grande trasferimento. Partenza ore 7:00. ~500 km via Fréjus o Monte Bianco.</description>
        <styleUrl>#tappa</styleUrl>
        <Point>
          <coordinates>4.8286,46.3069,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>4 - Chambord + Cheverny (3ª notte)</name>
        <description>Dom 23 ago - 3ª notte

Château de Chambord + Cheverny (ispirazione di Tintin!). Valle della Loira.</description>
        <styleUrl>#tappa</styleUrl>
        <Point>
          <coordinates>1.5171,47.6161,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>5 - Chenonceau → Alençon (4ª notte)</name>
        <description>Lun 24 ago - 4ª notte

Château de Chenonceau al mattino (prenotare online!), poi trasferimento verso Normandia.</description>
        <styleUrl>#tappa</styleUrl>
        <Point>
          <coordinates>1.0698,47.3248,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>6 - Mont-Saint-Michel (5ª notte)</name>
        <description>Mar 25 ago - 5ª notte

L'abbazia più visitata di Francia. Arrivare entro le 10 o dopo le 17. Maree spettacolari.</description>
        <styleUrl>#tappa</styleUrl>
        <Point>
          <coordinates>-1.5116,48.6359,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>7 - Bayeux + Étretat (6ª notte)</name>
        <description>Mer 26 ago - 6ª notte

Arazzo di Bayeux + Omaha Beach + Pointe du Hoc + scogliere di Étretat al tramonto.</description>
        <styleUrl>#tappa</styleUrl>
        <Point>
          <coordinates>0.7033,49.3414,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>8 - Honfleur → Versailles (7ª notte)</name>
        <description>Gio 27 ago - 7ª notte

Porto di Honfleur al mattino, poi trasferimento a Versailles.</description>
        <styleUrl>#tappa</styleUrl>
        <Point>
          <coordinates>0.2333,49.3187,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>9 - Versailles + Parigi (8ª notte)</name>
        <description>Ven 28 ago - 8ª notte

Versailles (Grandes Eaux il venerdì!), poi Torre Eiffel + Sainte-Chapelle + Montmartre.</description>
        <styleUrl>#tappa</styleUrl>
        <Point>
          <coordinates>2.1204,48.8049,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>10 - Disneyland Paris (9ª notte)</name>
        <description>Sab 29 ago - 9ª notte

Giornata intera a Disneyland Paris. Entrare all'apertura! Lightning Lane obbligatorio.</description>
        <styleUrl>#tappa</styleUrl>
        <Point>
          <coordinates>2.7836,48.8674,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>11 - Aosta (10ª notte)</name>
        <description>Dom 30 ago - 10ª notte

Rientro verso Italia. Partenza ORE 6:30 - bollino rosso domenica. Notte ad Aosta per consegna serena.</description>
        <styleUrl>#tappa</styleUrl>
        <Point>
          <coordinates>7.32,45.7369,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>12 - Milano (consegna)</name>
        <description>Lun 31 ago - Consegna ore 9:00

Consegna camper ore 9:00. Partenza da Aosta ore 7:00.</description>
        <styleUrl>#tappa</styleUrl>
        <Point>
          <coordinates>9.1859,45.4654,0</coordinates>
        </Point>
      </Placemark>
    </Folder>
    <Folder>
      <name>⭐ Luoghi da visitare</name>
      <description>Castelli, spiagge, monumenti e attrazioni</description>
      <Folder>
        <name>🌿 Valle della Loira</name>
        <Placemark>
          <name>Château de Chambord</name>
          <description>Il castello più grande della Loira. Scala a doppia elica di Leonardo. Arrivare entro le 10 in agosto.</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>1.5171,47.6161,0</coordinates>
          </Point>
        </Placemark>
        <Placemark>
          <name>Château de Cheverny</name>
          <description>Ha ispirato il castello di Tintin! Canile con 100 cani da caccia. Perfetto per bambini.</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>1.4583,47.5,0</coordinates>
          </Point>
        </Placemark>
        <Placemark>
          <name>Château de Chenonceau</name>
          <description>Il castello sul fiume Cher. PRENOTARE ONLINE - code enormi in agosto.</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>1.0698,47.3248,0</coordinates>
          </Point>
        </Placemark>
      </Folder>
      <Folder>
        <name>🌊 Normandia</name>
        <Placemark>
          <name>Mont-Saint-Michel</name>
          <description>Abbazia UNESCO. Maree tra le più forti d'Europa. Parcheggio camper da prenotare online.</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>-1.5116,48.6359,0</coordinates>
          </Point>
        </Placemark>
        <Placemark>
          <name>Arazzo di Bayeux</name>
          <description>70 metri di storia normanna dell'XI sec. Accessibile e affascinante per bambini.</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>-0.7033,49.2764,0</coordinates>
          </Point>
        </Placemark>
        <Placemark>
          <name>Omaha Beach</name>
          <description>Spiaggia dello sbarco D-Day. Cimitero Americano di Colleville-sur-Mer. Luogo di grande impatto.</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>-0.8611,49.3691,0</coordinates>
          </Point>
        </Placemark>
        <Placemark>
          <name>Pointe du Hoc</name>
          <description>Trincee e crateri dei bombardamenti ancora intatti. I bambini restano affascinati.</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>-0.9917,49.3964,0</coordinates>
          </Point>
        </Placemark>
        <Placemark>
          <name>Scogliere di Étretat</name>
          <description>Scogliere bianche più famose d'Europa. Passeggiata sulle falaise 1h. Tramonto magico.</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>0.2083,49.7083,0</coordinates>
          </Point>
        </Placemark>
        <Placemark>
          <name>Porto di Honfleur</name>
          <description>Porto più fotografato di Normandia. Case a graticcio colorate sul Vieux Bassin.</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>0.2333,49.4189,0</coordinates>
          </Point>
        </Placemark>
      </Folder>
      <Folder>
        <name>🗼 Parigi e dintorni</name>
        <Placemark>
          <name>Reggia di Versailles</name>
          <description>Galleria degli Specchi + Giardini Le Nôtre. Grandes Eaux Musicales ogni VENERDÌ estate!</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>2.1204,48.8049,0</coordinates>
          </Point>
        </Placemark>
        <Placemark>
          <name>Torre Eiffel</name>
          <description>PRENOTARE MESI PRIMA in agosto. Salita al 2° piano. Picnic sul Champ-de-Mars.</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>2.2945,48.8584,0</coordinates>
          </Point>
        </Placemark>
        <Placemark>
          <name>Sainte-Chapelle</name>
          <description>Vetrate gotiche del XIII sec. da togliere il fiato. I bambini restano a bocca aperta.</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>2.345,48.8554,0</coordinates>
          </Point>
        </Placemark>
        <Placemark>
          <name>Montmartre - Sacré-Cœur</name>
          <description>Vista panoramica su Parigi. Artisti in Place du Tertre. Stradine caratteristiche.</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>2.3431,48.8867,0</coordinates>
          </Point>
        </Placemark>
        <Placemark>
          <name>Disneyland Paris</name>
          <description>PRENOTARE SUBITO - sold out in agosto. Entrare all'apertura ore 9:00. App My Disney Experience.</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>2.7836,48.8674,0</coordinates>
          </Point>
        </Placemark>
      </Folder>
    </Folder>
