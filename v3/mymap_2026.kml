      </LabelStyle>
    </Style>
    <Folder>
      <name>Tappe del percorso</name>
      <description>12 tappe dal 21 al 31 agosto</description>
      <Placemark>
        <name>1 - Milano (partenza)</name>
        <description>Ven 21 ago | Ritiro camper ore 15:00. Partenza ore 19:00 verso Aosta.</description>
        <styleUrl>#tappa</styleUrl>
        <Point>
          <coordinates>9.1859,45.4654,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>2 - Aosta (1ª notte)</name>
        <description>Ven 21 ago | ~110 km. Prima notte corta per familiarizzare col camper.</description>
        <styleUrl>#tappa</styleUrl>
        <Point>
          <coordinates>7.3200,45.7369,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>3 - Versailles (2ª notte)</name>
        <description>Sab 22 ago | ~730 km. GIORNO DI ECCEZIONE. Aosta→Monte Bianco→Lione(pranzo)→Digione→Versailles.</description>
        <styleUrl>#tappa</styleUrl>
        <Point>
          <coordinates>2.1204,48.8049,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>4 - Versailles (3ª notte)</name>
        <description>Dom 23 ago | Reggia di Versailles giornata intera.</description>
        <styleUrl>#tappa</styleUrl>
        <Point>
          <coordinates>2.1204,48.8049,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>5 - Versailles (4ª notte)</name>
        <description>Lun 24 ago | Parigi via RER: Torre Eiffel, Sainte-Chapelle, Montmartre.</description>
        <styleUrl>#tappa</styleUrl>
        <Point>
          <coordinates>2.1204,48.8049,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>6 - Disneyland / Disney area (5ª notte)</name>
        <description>Mar 25 ago | Disneyland Paris giornata intera. RER A da Versailles.</description>
        <styleUrl>#tappa</styleUrl>
        <Point>
          <coordinates>2.7836,48.8674,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>7 - Étretat (6ª notte)</name>
        <description>Mer 26 ago | ~260 km. Bayeux + Omaha Beach + Pointe du Hoc + scogliere Étretat.</description>
        <styleUrl>#tappa</styleUrl>
        <Point>
          <coordinates>0.2083,49.7083,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>8 - Mont-Saint-Michel (7ª notte)</name>
        <description>Gio 27 ago | ~195 km. Honfleur sosta breve. Arrivo MSM al tramonto.</description>
        <styleUrl>#tappa</styleUrl>
        <Point>
          <coordinates>-1.5116,48.6359,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>9 - Loira / Bracieux (8ª notte)</name>
        <description>Ven 28 ago | ~280 km. MSM mattina (abbazia) poi trasferimento Loira.</description>
        <styleUrl>#tappa</styleUrl>
        <Point>
          <coordinates>1.5333,47.5667,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>10 - Loira / Tours (9ª notte)</name>
        <description>Sab 29 ago | ~60 km. Chambord (mattina) + Chenonceau (pomeriggio). Giornata dedicata ai castelli.</description>
        <styleUrl>#tappa</styleUrl>
        <Point>
          <coordinates>0.6900,47.3900,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>11 - Chambéry (10ª notte)</name>
        <description>Dom 30 ago | ~490 km. GIORNO DI ECCEZIONE. Bollino rosso: partenza ore 6:30.</description>
        <styleUrl>#tappa</styleUrl>
        <Point>
          <coordinates>5.9200,45.5646,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>12 - Milano (consegna)</name>
        <description>Lun 31 ago | ~200 km. Partenza Chambéry ore 6:30. Consegna camper ore 9:00 ✅</description>
        <styleUrl>#tappa</styleUrl>
        <Point>
          <coordinates>9.1859,45.4654,0</coordinates>
        </Point>
      </Placemark>
    </Folder>
    <Folder>
      <name>Luoghi da visitare</name>
      <Folder>
        <name>Italia e percorso andata</name>
        <Placemark>
          <name>Traforo del Fréjus</name>
          <description>~€60/camper. Giorno 1 (andata) e giorno 11 (rientro).</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>6.6678,45.1517,0</coordinates>
          </Point>
        </Placemark>
        <Placemark>
          <name>Traforo Monte Bianco</name>
          <description>~€50/camper. Giorno 2 (Aosta→Versailles, grande trasferimento).</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>6.8694,45.9237,0</coordinates>
          </Point>
        </Placemark>
        <Placemark>
          <name>Lione — sosta pranzo G2</name>
          <description>Sosta pranzo ~1h durante il grande trasferimento Aosta→Versailles. Autostrada A40/A6.</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>4.8357,45.7640,0</coordinates>
          </Point>
        </Placemark>
      </Folder>
      <Folder>
        <name>Parigi e dintorni</name>
        <Placemark>
          <name>Reggia di Versailles</name>
          <description>Galleria degli Specchi + Giardini Le Nôtre. Prenotare online. Giorno 4 (lun 24 ago).</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>2.1204,48.8049,0</coordinates>
          </Point>
        </Placemark>
        <Placemark>
          <name>Torre Eiffel</name>
          <description>PRENOTARE MESI PRIMA. Salita 2° piano. Picnic Champ-de-Mars. Giorno 5 (mar 25 ago).</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>2.2945,48.8584,0</coordinates>
          </Point>
        </Placemark>
        <Placemark>
          <name>Sainte-Chapelle</name>
          <description>Vetrate gotiche XIII sec. Imperdibile con bambini. Giorno 5.</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>2.3450,48.8554,0</coordinates>
          </Point>
        </Placemark>
        <Placemark>
          <name>Montmartre – Sacré-Cœur</name>
          <description>Vista panoramica su Parigi. Artisti in Place du Tertre. Giorno 5.</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>2.3431,48.8867,0</coordinates>
          </Point>
        </Placemark>
        <Placemark>
          <name>Disneyland Paris</name>
          <description>MARTEDÌ 25 agosto. RER A diretto da Versailles. PRENOTARE SUBITO. 2 parchi.</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>2.7836,48.8674,0</coordinates>
          </Point>
        </Placemark>
      </Folder>
      <Folder>
        <name>Normandia</name>
        <Placemark>
          <name>Bayeux — Arazzo XI sec.</name>
          <description>70 metri di storia normanna. Cattedrale. Accessibile per bambini. Giorno 7 (gio 27 ago).</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>-0.7033,49.2764,0</coordinates>
          </Point>
        </Placemark>
        <Placemark>
          <name>Omaha Beach</name>
          <description>Spiaggia D-Day. Cimitero Americano Colleville-sur-Mer. Giorno 7.</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>-0.8611,49.3691,0</coordinates>
          </Point>
        </Placemark>
        <Placemark>
          <name>Pointe du Hoc</name>
          <description>Trincee e crateri intatti. I bambini restano affascinati. Giorno 7.</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>-0.9917,49.3964,0</coordinates>
          </Point>
        </Placemark>
        <Placemark>
          <name>Scogliere di Étretat</name>
          <description>Scogliere bianche più famose d'Europa. Passeggiata falaise 1h. Tramonto magico. Giorno 7 (pomeriggio).</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>0.2083,49.7083,0</coordinates>
          </Point>
        </Placemark>
        <Placemark>
          <name>Porto di Honfleur (sosta)</name>
          <description>Sosta caffè ~30 min. Vieux Bassin con case a graticcio colorate. Giorno 8 (ven 28 ago).</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>0.2333,49.4189,0</coordinates>
          </Point>
        </Placemark>
        <Placemark>
          <name>Mont-Saint-Michel</name>
          <description>Abbazia UNESCO. Maree enormi. Arrivare dopo le 17 (giorno 8). Mattina completa giorno 9. Parking da prenotare.</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>-1.5116,48.6359,0</coordinates>
          </Point>
        </Placemark>
      </Folder>
      <Folder>
        <name>Valle della Loira</name>
        <Placemark>
          <name>Château de Chambord</name>
          <description>Il più grande della Loira. Scala a doppia elica di Leonardo. Giorno 10 (dom 30 ago) ore 9:00-11:00.</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>1.5171,47.6161,0</coordinates>
          </Point>
        </Placemark>
        <Placemark>
          <name>Château de Chenonceau</name>
          <description>Castello sul fiume Cher. PRENOTARE ONLINE — code enormi in agosto. Giorno 10 ore 12:00-14:00.</description>
          <styleUrl>#visita</styleUrl>
          <Point>
            <coordinates>1.0698,47.3248,0</coordinates>
          </Point>
        </Placemark>
      </Folder>
    </Folder>
