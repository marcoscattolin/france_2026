<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>Francia Camper FINALE — 21-31 Agosto 2025</name>
    <description>Milano→Aosta→Versailles/Parigi→Disneyland(mar25)→Étretat→Mont-Saint-Michel→Loira(Chambord+Chenonceau)→Chambéry→Milano
4 camper·4 famiglie·bambini 8-10 anni·10 notti</description>
